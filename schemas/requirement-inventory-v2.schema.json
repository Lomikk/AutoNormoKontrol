{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autonormokontrol.local/schemas/requirement-inventory-v2.schema.json",
  "title": "AutoNormoKontrol canonical requirement inventory v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source", "entries"],
  "properties": {
    "schema_version": { "const": 2 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "manifest"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "manifest": { "type": "string", "minLength": 1 }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "summary", "source"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": {
            "enum": ["requirement", "definition", "group", "example", "form"]
          },
          "summary": { "type": "string", "minLength": 1 },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": ["document_id", "clause", "locator"],
            "properties": {
              "document_id": { "type": "string", "minLength": 1 },
              "clause": { "type": "string", "minLength": 1 },
              "locator": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
