{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autonormokontrol.local/schemas/workspace-v1.schema.json",
  "title": "AutoNormoKontrol workspace manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile", "engine", "document"],
  "properties": {
    "schema_version": { "const": 1 },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "manifest", "digest"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+$"
        },
        "manifest": {
          "type": "string",
          "pattern": "^profiles/[a-z0-9]+(?:-[a-z0-9]+)*/profile\\.yaml$"
        },
        "digest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum_version", "created_with"],
      "properties": {
        "minimum_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "created_with": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "content"],
      "properties": {
        "type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "content": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^content/.+\\.md$"
          }
        }
      }
    }
  }
}
