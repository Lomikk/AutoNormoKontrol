{
    "schema_version":  2,
    "source":  {
                   "id":  "STO-17-2008",
                   "title":  "СТО ЮУрГУ 17-2008. Реферат. Требования к содержанию и оформлению",
                   "manifest":  "sources/susu/sto-17-2008/manifest.json"
               },
    "entries":  [
                    {
                        "id":  "STO17-1",
                        "kind":  "requirement",
                        "clause":  "1",
                        "summary":  "Область применения стандарта."
                    },
                    {
                        "id":  "STO17-2",
                        "kind":  "requirement",
                        "clause":  "2",
                        "summary":  "Нормативные ссылки стандарта."
                    },
                    {
                        "id":  "STO17-3",
                        "kind":  "group",
                        "clause":  "3",
                        "summary":  "Термины и определения."
                    },
                    {
                        "id":  "STO17-3.1",
                        "kind":  "definition",
                        "clause":  "3.1",
                        "summary":  "Определение абзаца."
                    },
                    {
                        "id":  "STO17-3.2",
                        "kind":  "definition",
                        "clause":  "3.2",
                        "summary":  "Определение аннотации."
                    },
                    {
                        "id":  "STO17-3.3",
                        "kind":  "definition",
                        "clause":  "3.3",
                        "summary":  "Определение введения."
                    },
                    {
                        "id":  "STO17-3.4",
                        "kind":  "definition",
                        "clause":  "3.4",
                        "summary":  "Определение главы."
                    },
                    {
                        "id":  "STO17-3.5",
                        "kind":  "definition",
                        "clause":  "3.5",
                        "summary":  "Определение заголовка."
                    },
                    {
                        "id":  "STO17-3.6",
                        "kind":  "definition",
                        "clause":  "3.6",
                        "summary":  "Определение заключения."
                    },
                    {
                        "id":  "STO17-3.7",
                        "kind":  "definition",
                        "clause":  "3.7",
                        "summary":  "Определение параграфа."
                    },
                    {
                        "id":  "STO17-3.8",
                        "kind":  "definition",
                        "clause":  "3.8",
                        "summary":  "Определение раздела."
                    },
                    {
                        "id":  "STO17-3.9",
                        "kind":  "definition",
                        "clause":  "3.9",
                        "summary":  "Определение реферата."
                    },
                    {
                        "id":  "STO17-3.10",
                        "kind":  "definition",
                        "clause":  "3.10",
                        "summary":  "Определение рубрики."
                    },
                    {
                        "id":  "STO17-3.11",
                        "kind":  "definition",
                        "clause":  "3.11",
                        "summary":  "Определение сводного реферата."
                    },
                    {
                        "id":  "STO17-3.12",
                        "kind":  "definition",
                        "clause":  "3.12",
                        "summary":  "Определение части."
                    },
                    {
                        "id":  "STO17-3.13",
                        "kind":  "definition",
                        "clause":  "3.13",
                        "summary":  "Определение эпиграфа."
                    },
                    {
                        "id":  "STO17-4",
                        "kind":  "group",
                        "clause":  "4",
                        "summary":  "Основные нормативные положения."
                    },
                    {
                        "id":  "STO17-4.1",
                        "kind":  "group",
                        "clause":  "4.1",
                        "summary":  "Общие положения о реферате."
                    },
                    {
                        "id":  "STO17-4.1.1",
                        "kind":  "requirement",
                        "clause":  "4.1.1",
                        "summary":  "Функции учебного реферата: обобщение информации, представление содержания первичного произведения и предоставление сведений о нём."
                    },
                    {
                        "id":  "STO17-4.1.2",
                        "kind":  "requirement",
                        "clause":  "4.1.2",
                        "summary":  "Содержание реферата включает информацию из первичного источника, раскрывает тему и сохраняет логическую целостность изложения."
                    },
                    {
                        "id":  "STO17-4.1.3",
                        "kind":  "requirement",
                        "clause":  "4.1.3",
                        "summary":  "Реферат начинается с существа работы; лишние вводные фразы, несущественные исторические справки и общеизвестные положения не приводятся."
                    },
                    {
                        "id":  "STO17-4.1.4",
                        "kind":  "requirement",
                        "clause":  "4.1.4",
                        "summary":  "Описание методов приводится для новых или особо значимых методов; для экспериментальных работ указываются источники данных и их обработка."
                    },
                    {
                        "id":  "STO17-4.1.5",
                        "kind":  "requirement",
                        "clause":  "4.1.5",
                        "summary":  "В реферате приводятся основные результаты и сведения о характере числовых результатов, точности, надёжности и достоверности."
                    },
                    {
                        "id":  "STO17-4.1.6",
                        "kind":  "requirement",
                        "clause":  "4.1.6",
                        "summary":  "Допускается различная детализация изложения содержания источника и ограничение основной темой и результатами источника."
                    },
                    {
                        "id":  "STO17-4.1.7",
                        "kind":  "requirement",
                        "clause":  "4.1.7",
                        "summary":  "Материал реферата излагается кратко и точно, с синтаксическими конструкциями научных и технических документов."
                    },
                    {
                        "id":  "STO17-4.1.8",
                        "kind":  "requirement",
                        "clause":  "4.1.8",
                        "summary":  "Используется стандартизованная терминология; непривычные термины и символы разъясняются при первом упоминании, сокращения должны быть понятны из контекста."
                    },
                    {
                        "id":  "STO17-4.2",
                        "kind":  "group",
                        "clause":  "4.2",
                        "summary":  "Структура реферата."
                    },
                    {
                        "id":  "STO17-4.2.1",
                        "kind":  "requirement",
                        "clause":  "4.2.1",
                        "summary":  "Структурные элементы реферата: титульный лист, аннотация, оглавление, введение, основная часть, заключение, библиографический список, а также при необходимости обозначения, сокращения и приложения."
                    },
                    {
                        "id":  "STO17-4.2.2",
                        "kind":  "group",
                        "clause":  "4.2.2",
                        "summary":  "Требования к содержанию структурных элементов."
                    },
                    {
                        "id":  "STO17-4.2.2.1",
                        "kind":  "requirement",
                        "clause":  "4.2.2.1",
                        "summary":  "Титульный лист является первой страницей и содержит сведения об организациях, теме, дисциплине, руководителе, студенте, месте и дате составления."
                    },
                    {
                        "id":  "STO17-4.2.2.2",
                        "kind":  "requirement",
                        "clause":  "4.2.2.2",
                        "summary":  "Аннотация содержит сведения об объёме и элементах реферата, исполнителе, цели и задачах, а также краткую характеристику содержания."
                    },
                    {
                        "id":  "STO17-4.2.2.3",
                        "kind":  "requirement",
                        "clause":  "4.2.2.3",
                        "summary":  "Оглавление включает введение, наименования структурных частей, заключение, библиографический список и приложения с начальными номерами страниц."
                    },
                    {
                        "id":  "STO17-4.2.2.4",
                        "kind":  "requirement",
                        "clause":  "4.2.2.4",
                        "summary":  "Введение содержит оценку современного состояния вопроса, цели и задачи, обоснование источников, историю вопроса или значимость темы."
                    },
                    {
                        "id":  "STO17-4.2.2.5",
                        "kind":  "requirement",
                        "clause":  "4.2.2.5",
                        "summary":  "При значительном количестве обозначений и сокращений приводится соответствующий раздел с алфавитным перечнем и пояснениями."
                    },
                    {
                        "id":  "STO17-4.2.2.6",
                        "kind":  "requirement",
                        "clause":  "4.2.2.6",
                        "summary":  "Основная часть может состоять из тематически связанных разделов с итогами и выводами; в ней приводятся данные по сущности темы."
                    },
                    {
                        "id":  "STO17-4.2.2.7",
                        "kind":  "requirement",
                        "clause":  "4.2.2.7",
                        "summary":  "Заключение содержит выводы по теме, оценки полноты решения задач и достижения цели, а также рекомендации по использованию результатов."
                    },
                    {
                        "id":  "STO17-4.2.2.8",
                        "kind":  "requirement",
                        "clause":  "4.2.2.8",
                        "summary":  "Библиографический список содержит использованные источники, включает не менее трёх источников и учитывает современность изданий."
                    },
                    {
                        "id":  "STO17-4.2.2.9",
                        "kind":  "requirement",
                        "clause":  "4.2.2.9",
                        "summary":  "Приложения включаются при необходимости и могут содержать связанные с темой материалы, не вошедшие в основную часть."
                    },
                    {
                        "id":  "STO17-4.3",
                        "kind":  "group",
                        "clause":  "4.3",
                        "summary":  "Оформление реферата."
                    },
                    {
                        "id":  "STO17-4.3.1",
                        "kind":  "group",
                        "clause":  "4.3.1",
                        "summary":  "Общие требования к оформлению."
                    },
                    {
                        "id":  "STO17-4.3.1.1",
                        "kind":  "requirement",
                        "clause":  "4.3.1.1",
                        "summary":  "Реферат оформляется по настоящему стандарту на листах белой бумаги формата А4."
                    },
                    {
                        "id":  "STO17-4.3.1.2",
                        "kind":  "requirement",
                        "clause":  "4.3.1.2",
                        "summary":  "Установлены требования к набору, абзацному отступу, полям, качеству текста, исправлениям, именам собственным, висячим строкам и сокращениям."
                    },
                    {
                        "id":  "STO17-4.3.2",
                        "kind":  "group",
                        "clause":  "4.3.2",
                        "summary":  "Построение реферата и нумерация элементов."
                    },
                    {
                        "id":  "STO17-4.3.2.1",
                        "kind":  "requirement",
                        "clause":  "4.3.2.1",
                        "summary":  "Основная часть работы делится на части, разделы, главы, подразделы, пункты и параграфы."
                    },
                    {
                        "id":  "STO17-4.3.2.2",
                        "kind":  "requirement",
                        "clause":  "4.3.2.2",
                        "summary":  "Разделы, подразделы, пункты и подпункты нумеруются и оформляются арабскими цифрами с абзацного отступа."
                    },
                    {
                        "id":  "STO17-4.3.2.3",
                        "kind":  "requirement",
                        "clause":  "4.3.2.3",
                        "summary":  "Установлена составная нумерация подразделов, пунктов и подпунктов; точка после номера не ставится."
                    },
                    {
                        "id":  "STO17-4.3.2.4",
                        "kind":  "requirement",
                        "clause":  "4.3.2.4",
                        "summary":  "Подразделы, пункты и подпункты вводятся при необходимости выделения более одного соответствующего элемента."
                    },
                    {
                        "id":  "STO17-4.3.2.5",
                        "kind":  "requirement",
                        "clause":  "4.3.2.5",
                        "summary":  "Разделы и подразделы имеют точные и краткие заголовки; установлены правила нумерации и оформления заголовков разделов и выводов."
                    },
                    {
                        "id":  "STO17-4.3.2.6",
                        "kind":  "requirement",
                        "clause":  "4.3.2.6",
                        "summary":  "Наименования структурных элементов служат заголовками первого уровня; установлено оформление заголовков разных уровней."
                    },
                    {
                        "id":  "STO17-4.3.2.7",
                        "kind":  "requirement",
                        "clause":  "4.3.2.7",
                        "summary":  "Заголовки подразделов, пунктов и подпунктов печатаются с абзацного отступа и прописной буквы."
                    },
                    {
                        "id":  "STO17-4.3.2.8",
                        "kind":  "requirement",
                        "clause":  "4.3.2.8",
                        "summary":  "Установлены правила состава, переноса, знаков препинания и размещения заголовков."
                    },
                    {
                        "id":  "STO17-4.3.2.9",
                        "kind":  "requirement",
                        "clause":  "4.3.2.9",
                        "summary":  "После заголовка в конце страницы размещается не менее трёх строк текста."
                    },
                    {
                        "id":  "STO17-4.3.2.10",
                        "kind":  "requirement",
                        "clause":  "4.3.2.10",
                        "summary":  "Пункты и подпункты внутри параграфа допускается выделять без нумерации шрифтовым оформлением."
                    },
                    {
                        "id":  "STO17-4.3.2.11",
                        "kind":  "requirement",
                        "clause":  "4.3.2.11",
                        "summary":  "Установлены способы оформления перечислений внутри подразделов, пунктов и подпунктов."
                    },
                    {
                        "id":  "STO17-4.3.3",
                        "kind":  "group",
                        "clause":  "4.3.3",
                        "summary":  "Нумерация страниц."
                    },
                    {
                        "id":  "STO17-4.3.3.1",
                        "kind":  "requirement",
                        "clause":  "4.3.3.1",
                        "summary":  "Страницы нумеруются арабскими цифрами сквозной нумерацией; номер ставится в центре нижней части листа без точки."
                    },
                    {
                        "id":  "STO17-4.3.3.2",
                        "kind":  "requirement",
                        "clause":  "4.3.3.2",
                        "summary":  "Титульный лист включается в общую нумерацию страниц реферата."
                    },
                    {
                        "id":  "STO17-4.3.4",
                        "kind":  "group",
                        "clause":  "4.3.4",
                        "summary":  "Иллюстрации."
                    },
                    {
                        "id":  "STO17-4.3.4.1",
                        "kind":  "requirement",
                        "clause":  "4.3.4.1",
                        "summary":  "Иллюстрации располагаются после первого упоминания или на следующей странице; на все иллюстрации даются ссылки."
                    },
                    {
                        "id":  "STO17-4.3.4.2",
                        "kind":  "requirement",
                        "clause":  "4.3.4.2",
                        "summary":  "Чертежи, графики, диаграммы, схемы и иллюстрации соответствуют указанным стандартам; допускается компьютерное выполнение."
                    },
                    {
                        "id":  "STO17-4.3.4.3",
                        "kind":  "requirement",
                        "clause":  "4.3.4.3",
                        "summary":  "Фотоснимки меньше формата А4 наклеиваются на стандартные листы белой бумаги."
                    },
                    {
                        "id":  "STO17-4.3.4.4",
                        "kind":  "requirement",
                        "clause":  "4.3.4.4",
                        "summary":  "Иллюстрации, кроме приложений, нумеруются арабскими цифрами сквозной нумерацией; установлено размещение слова «Рисунок» и наименования."
                    },
                    {
                        "id":  "STO17-4.3.4.5",
                        "kind":  "requirement",
                        "clause":  "4.3.4.5",
                        "summary":  "Допускается нумерация иллюстраций в пределах раздела."
                    },
                    {
                        "id":  "STO17-4.3.4.6",
                        "kind":  "requirement",
                        "clause":  "4.3.4.6",
                        "summary":  "Иллюстрации могут иметь наименование и пояснительные данные; установлено размещение подписи."
                    },
                    {
                        "id":  "STO17-4.3.4.7",
                        "kind":  "requirement",
                        "clause":  "4.3.4.7",
                        "summary":  "Иллюстрации каждого приложения имеют отдельную нумерацию с обозначением приложения."
                    },
                    {
                        "id":  "STO17-4.3.4.8",
                        "kind":  "requirement",
                        "clause":  "4.3.4.8",
                        "summary":  "Установлена форма ссылок на иллюстрации при сквозной и разделовой нумерации."
                    },
                    {
                        "id":  "STO17-4.3.4.9",
                        "kind":  "requirement",
                        "clause":  "4.3.4.9",
                        "summary":  "Оформление диаграмм функциональной зависимости выполняется по указанному стандарту."
                    },
                    {
                        "id":  "STO17-4.3.4.10",
                        "kind":  "requirement",
                        "clause":  "4.3.4.10",
                        "summary":  "Значения переменных откладываются на осях координат в линейном или нелинейном масштабе."
                    },
                    {
                        "id":  "STO17-4.3.4.11",
                        "kind":  "requirement",
                        "clause":  "4.3.4.11",
                        "summary":  "Установлено направление откладывания величин в прямоугольной и полярной системах координат."
                    },
                    {
                        "id":  "STO17-4.3.5",
                        "kind":  "group",
                        "clause":  "4.3.5",
                        "summary":  "Схемы."
                    },
                    {
                        "id":  "STO17-4.3.5.1",
                        "kind":  "requirement",
                        "clause":  "4.3.5.1",
                        "summary":  "Определены назначение схем и общие требования к их выполнению."
                    },
                    {
                        "id":  "STO17-4.3.5.2",
                        "kind":  "requirement",
                        "clause":  "4.3.5.2",
                        "summary":  "Кинематические схемы и их элементы выполняются по указанным стандартам."
                    },
                    {
                        "id":  "STO17-4.3.5.3",
                        "kind":  "requirement",
                        "clause":  "4.3.5.3",
                        "summary":  "Гидравлические и пневматические схемы и их элементы выполняются по указанным стандартам."
                    },
                    {
                        "id":  "STO17-4.3.5.4",
                        "kind":  "requirement",
                        "clause":  "4.3.5.4",
                        "summary":  "Электрические схемы соответствуют указанным стандартам и содержат позиционные обозначения элементов."
                    },
                    {
                        "id":  "STO17-4.3.6",
                        "kind":  "group",
                        "clause":  "4.3.6",
                        "summary":  "Таблицы."
                    },
                    {
                        "id":  "STO17-4.3.6.1",
                        "kind":  "requirement",
                        "clause":  "4.3.6.1",
                        "summary":  "Таблицы применяются для наглядности; установлены правила названия и его размещения."
                    },
                    {
                        "id":  "STO17-4.3.6.2",
                        "kind":  "requirement",
                        "clause":  "4.3.6.2",
                        "summary":  "Таблица располагается непосредственно после первого упоминания или на следующей странице."
                    },
                    {
                        "id":  "STO17-4.3.6.3",
                        "kind":  "requirement",
                        "clause":  "4.3.6.3",
                        "summary":  "На все таблицы в реферате даются ссылки с указанием номера."
                    },
                    {
                        "id":  "STO17-4.3.6.4",
                        "kind":  "requirement",
                        "clause":  "4.3.6.4",
                        "summary":  "Установлены правила переноса таблицы с большим количеством строк."
                    },
                    {
                        "id":  "STO17-4.3.6.5",
                        "kind":  "requirement",
                        "clause":  "4.3.6.5",
                        "summary":  "Цифровой материал, как правило, оформляется в виде таблиц."
                    },
                    {
                        "id":  "STO17-4.3.6.6",
                        "kind":  "requirement",
                        "clause":  "4.3.6.6",
                        "summary":  "Таблицы, кроме приложений, нумеруются арабскими цифрами сквозной нумерацией; допускается нумерация в пределах раздела."
